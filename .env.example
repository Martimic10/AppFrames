# Public site URL (Stripe success/cancel redirects). Use your production domain on Vercel.
# Example: https://appframes.app
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Stripe — https://dashboard.stripe.com/apikeys
# Use sk_test_... while testing, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret — https://dashboard.stripe.com/webhooks
# Point webhook to: https://YOUR_DOMAIN/api/stripe/webhook
# Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: fixed Stripe Price ID instead of dynamic $29 price_data checkout
# STRIPE_PRICE_ID=price_...

# Signs Pro license cookies (use a long random string in production)
PRO_LICENSE_SECRET=change-me-to-a-long-random-string
